
import streamlit as st
from datetime import datetime
import json
import os

# --- FUNCOES DE ARMAZENAMENTO ---
def carregar_dados():
    if os.path.exists('dados.json'):
        with open('dados.json', 'r') as f:
            return json.load(f)
    return {"estudos": [], "gastos": 0.0}

def salvar_dados(dados):
    with open('dados.json', 'w') as f:
        json.dump(dados, f)

# Inicializar dados
if 'dados' not in st.session_state:
    st.session_state.dados = carregar_dados()

# --- CONFIGURACAO DO APP ---
st.set_page_config(page_title="Minha Extensao", layout="centered")

# --- LOGICA DE HORARIO E PROXIMA ACAO ---
agora = datetime.now()
hora_atual = agora.time()
dia_semana = agora.weekday()

def obter_proxima_acao():
    if dia_semana < 5: # Seg a Sex
        if hora_atual < datetime.strptime("07:30", "%H:%M").time():
            return "🌅 PROXIMA ACAO: Ir para o trabalho (Pegar Marmita!)"
        elif hora_atual < datetime.strptime("17:00", "%H:%M").time():
            return "💪 PROXIMA ACAO: Academia (Janela das 17:10)"
        elif hora_atual < datetime.strptime("18:30", "%H:%M").time():
            return "📚 PROXIMA ACAO: Ir para a Faculdade"
        elif hora_atual < datetime.strptime("22:30", "%H:%M").time():
            return "🏠 PROXIMA ACAO: Voltar para casa e descansar"
    elif dia_semana == 5: # Sabado
        if hora_atual < datetime.strptime("11:10", "%H:%M").time():
            return "💪 PROXIMA ACAO: Academia pos-aula"
        elif hora_atual < datetime.strptime("13:20", "%H:%M").time():
            return "🚗 PROXIMA ACAO: Buscar esposa no trabalho"
    return "🍱 PROXIMA ACAO: Organizacao pessoal e descanso"

# --- INTERFACE ---
st.title("🧬 Minha Extensao")

# Card de Proxima Acao (Destaque no Inicio)
st.error(obter_proxima_acao()) 

st.divider()

# Abas Interativas
tab1, tab2, tab3 = st.tabs(["📚 Estudos", "💰 Financas", "⚙️ Config"])

with tab1:
    st.subheader("Meus Estudos")
    novo_estudo = st.text_input("O que precisa estudar?")
    if st.button("Salvar Lembrete de Estudo"):
        if novo_estudo:
            st.session_state.dados["estudos"].append(novo_estudo)
            salvar_dados(st.session_state.dados)
            st.success("Estudo salvo!")
    
    st.write("---")
    for i, estudo in enumerate(st.session_state.dados["estudos"]):
        st.write(f"{i+1}. {estudo}")

with tab2:
    st.subheader("Controle Financeiro")
    valor = st.number_input("Valor do gasto hoje (R$):", min_value=0.0, step=1.0)
    if st.button("Registrar Gasto"):
        st.session_state.dados["gastos"] += valor
        salvar_dados(st.session_state.dados)
        st.success(f"Gasto acumulado: R$ {st.session_state.dados['gastos']:.2f}")

with tab3:
    if st.button("Limpar Todos os Dados"):
        st.session_state.dados = {"estudos": [], "gastos": 0.0}
        salvar_dados(st.session_state.dados)
        st.warning("Dados apagados!")

st.caption(f"Atualizado em: {agora.strftime('%d/%m %H:%M')}")
